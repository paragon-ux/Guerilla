# Guerilla environment variables
# Copy to .env and adjust for local use

# Workspace path (default: .guerilla/ in current directory)
# GUERILLA_WORKSPACE=./workspace

# Log level: debug, info, warning, error
# GUERILLA_LOG_LEVEL=info

# Maximum payload size in bytes (default: 1048576)
# GUERILLA_MAX_PAYLOAD_SIZE=1048576
