{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guerilla.dev/schemas/adapter_descriptor.schema.json",
  "title": "Guerilla adapter descriptor",
  "type": "object",
  "required": [
    "adapter_id",
    "system_id",
    "name",
    "version",
    "trust_model",
    "state_boundaries",
    "capabilities",
    "authentication",
    "limitations",
    "extensions"
  ],
  "properties": {
    "adapter_id": {
      "$ref": "https://guerilla.dev/schemas/common.schema.json#/$defs/adapterId"
    },
    "system_id": {
      "$ref": "https://guerilla.dev/schemas/common.schema.json#/$defs/externalSystemId"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "version": {
      "$ref": "https://guerilla.dev/schemas/common.schema.json#/$defs/semver"
    },
    "trust_model": {
      "const": "trusted_in_process_python"
    },
    "state_boundaries": {
      "type": "array",
      "items": {
        "$ref": "https://guerilla.dev/schemas/state_boundary.schema.json"
      },
      "minItems": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "https://guerilla.dev/schemas/capability.schema.json"
      },
      "minItems": 1
    },
    "authentication": {
      "type": "object",
      "required": ["required", "credential_storage"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "credential_storage": {
          "enum": ["adapter_configuration", "secret_store", "none"]
        }
      },
      "additionalProperties": false
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "extensions": {
      "$ref": "https://guerilla.dev/schemas/common.schema.json#/$defs/extensions"
    }
  },
  "additionalProperties": false
}
